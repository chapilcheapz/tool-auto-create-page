{
  "name": "tool-auto-create-page",
  "version": "1.0.0",
  "private": true,
  "description": "Tool tự động tạo Facebook Page",
  "main": "server.js",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "postinstall": "node scripts/install-yt-dlp.js",
    "start": "node server.js",
    "dev:backend": "node --watch --watch-preserve-output server.js",
    "dev:frontend": "npm run dev -w frontend",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build -w frontend",
    "check:media-tools": "node scripts/check-media-tools.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2"
}
