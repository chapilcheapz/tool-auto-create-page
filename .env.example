# Cấu hình Supabase & Auth
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=videos
# Giới hạn preflight của ứng dụng. Supabase vẫn áp dụng quota của project.
SUPABASE_STORAGE_MAX_BYTES=524288000
# Tuỳ chọn chỉ áp dụng khi backend tạo bucket mới; để trống để kế thừa project.
SUPABASE_BUCKET_FILE_SIZE_LIMIT_BYTES=
SUPABASE_SIGNED_URL_TTL_SECONDS=86400
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# Cấu hình Express Backend
PORT=3456
COOKIE_SECRET=
FRONTEND_URL=http://localhost:5173
HTTP_REQUEST_TIMEOUT_MS=1800000
DOWNLOAD_DIR=
MEDIA_DIR=
MEDIA_MAX_UPLOAD_BYTES=524288000
MEDIA_MAX_SOURCE_SIZE=250M
MEDIA_PROCESS_TIMEOUT_MS=1800000
MEDIA_MAX_CONCURRENT_JOBS=2

# Cấu hình yt-dlp Cookie (Mặc định none - An toàn bảo mật)
# mode: none | file | browser
YTDLP_COOKIE_MODE=none
YTDLP_BROWSER=chrome
YTDLP_BROWSER_PROFILE=
YTDLP_COOKIES_FILE=
# ------------------------------------------------------------------
# YTDLP_COOKIES_BASE64: Dán nội dung cookies.txt đã encode Base64
# Phù hợp với Railway / Render (không có persistent volume).
# Cách encode trên Mac/Linux: base64 -w 0 cookies.txt
# Khi đặt biến này + YTDLP_COOKIE_MODE=file, server tự decode ra file tạm.
# ------------------------------------------------------------------
YTDLP_COOKIES_BASE64=
# Để trống để backend tự ưu tiên vendor/bin rồi mới dò PATH hệ thống.
# Chỉ điền khi server đã quản lý binary ở một đường dẫn tuyệt đối khác.
YTDLP_PATH=
FFMPEG_PATH=
FFPROBE_PATH=

# Đây là biến của bước npm install trên hosting (file .env không tự được npm đọc).
# Mặc định repo tải bản chính thức đã ghim và kiểm tra SHA-256 vào vendor/bin.
YTDLP_AUTO_INSTALL=1
YTDLP_VERSION=2026.07.04
